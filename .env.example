# Database (local Docker default shown)
DATABASE_URL=postgresql://sift:sift@localhost:5432/siftdb

# Anthropic API key (for Claude Haiku summaries)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Voyage AI API key (for embeddings, free 50M tokens/mo)
VOYAGE_API_KEY=va-xxxxx

# Shared secret for pipeline trigger (set same value in Vercel env)
PIPELINE_API_KEY=change-me-in-production

# Server config
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=info

# Error monitoring (Sentry) — OPTIONAL. Inert unless SENTRY_DSN is set.
# No PII is sent (send_default_pii=False). Tracing sample rate is conservative.
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Daily AI cost ceiling (sift-api#70) — OPTIONAL. Inert unless enabled.
# Tracks live-path Claude + Voyage spend; hard-stops paid calls past the limit.
AI_COST_GUARD_ENABLED=false
DAILY_AI_COST_LIMIT_USD=10.0
AI_COST_ALERT_THRESHOLD_RATIO=0.8

# Runtime LLM-judge for why_it_matters (sift-api#90) — OPTIONAL, OFF by default.
# When true, each line that survives the deterministic gate is judged (Sonnet)
# in the batch-result path and dropped if it restates or editorializes. Adds a
# paid call per kept line and increases suppression; respects the cost guard.
WHY_IT_MATTERS_JUDGE_ENABLED=false
